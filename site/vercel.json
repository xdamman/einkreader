{
  "rewrites": [
    {
      "source": "/.well-known/nostr.json",
      "destination": "/api/nostr-json"
    },
    {
      "source": "/:name([a-z0-9_]{5,20})",
      "destination": "/api/profile-page?name=:name"
    },
    {
      "source": "/:name([a-z0-9_]{5,20})/q/:qid([0-9a-f]{8,64})",
      "destination": "/api/profile-page?name=:name&qid=:qid"
    }
  ]
}
